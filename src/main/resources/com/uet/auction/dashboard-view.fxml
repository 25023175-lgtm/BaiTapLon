<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="600.0" prefWidth="850.0" stylesheets="@styles.css" styleClass="dashboard-root" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.uet.auction.DashboardController">

    <!-- PHẦN TOP: Thanh Header chứa Logo/Tên và Nút Đăng xuất -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="header-bar" BorderPane.alignment="CENTER">
            <children>
                <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1877F2;" text="Hệ thống Đấu giá UET" />

                <Region HBox.hgrow="ALWAYS" />

                <Button mnemonicParsing="false" onAction="#handleLogout" prefHeight="38.0" prefWidth="110.0" styleClass="btn-logout" text="Đăng xuất" />
            </children>
        </HBox>
    </top>

    <!-- PHẦN CENTER: Bảng danh sách sản phẩm -->
    <center>
        <VBox style="-fx-padding: 20;">
            <TableView fx:id="productTable" VBox.vgrow="ALWAYS" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-font-size: 14px;">
                <columns>
                    <TableColumn fx:id="colName" prefWidth="250.0" text="Tên sản phẩm" />
                    <TableColumn fx:id="colStartPrice" prefWidth="150.0" text="Giá khởi điểm" />
                    <TableColumn fx:id="colCurrentPrice" prefWidth="150.0" text="Giá hiện tại" />
                    <TableColumn fx:id="colStatus" prefWidth="150.0" text="Trạng thái" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </VBox>
    </center>

    <!-- PHẦN BOTTOM: Khung nhập sản phẩm -->
    <bottom>
        <VBox style="-fx-padding: 0 20 20 20;" BorderPane.alignment="CENTER">
            <HBox fx:id="addProductBox" alignment="CENTER" spacing="15.0" styleClass="add-product-card">
                <children>
                    <!-- Đã bóp nhỏ 2 ô nhập liệu xuống một chút để nhường chỗ -->
                    <TextField fx:id="newNameField" prefHeight="42.0" prefWidth="280.0" promptText="Tên sản phẩm đấu giá..." style="-fx-font-size: 14px; -fx-background-radius: 6;" />
                    <TextField fx:id="newPriceField" prefHeight="42.0" prefWidth="160.0" promptText="Giá khởi điểm (VNĐ)" style="-fx-font-size: 14px; -fx-background-radius: 6;" />

                    <!-- Đã thêm minWidth="-Infinity" để nút hiện full chữ -->
                    <Button minWidth="-Infinity" mnemonicParsing="false" onAction="#handleAddProduct" prefHeight="42.0" prefWidth="160.0" style="-fx-background-color: #42b72a; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" text="+ Thêm sản phẩm" />
                    <Button minWidth="-Infinity" mnemonicParsing="false" onAction="#handleDeleteProduct" prefHeight="42.0" prefWidth="80.0" style="-fx-background-color: #e41e3f; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" text="Xóa" />
                </children>
            </HBox>
        </VBox>
    </bottom>

</BorderPane>