<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.uet.auction.DashboardController">
   <top>
      <HBox prefHeight="100.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <children>
            <Label text="Hệ thống đấu giá UET">
               <graphic>
                  <Button mnemonicParsing="false" text="Đăng xuất" />
               </graphic>
            </Label>
         </children>
      </HBox>
   </top>
   <center>
      <TableView fx:id="productTable" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
        <columns>
          <TableColumn fx:id="colName" prefWidth="75.0" text="Tên sản phẩm" />
          <TableColumn fx:id="colStartPrice" prefWidth="75.0" text="Giá khởi điểm" />
            <TableColumn fx:id="colCurrentPrice" prefWidth="75.0" text="Giá hiện tại" />
            <TableColumn fx:id="colStatus" prefWidth="75.0" text="Trạng thái" />
        </columns>
      </TableView>
   </center>
   <bottom>
      <HBox fx:id="addProductBox" prefHeight="100.0" prefWidth="200.0" spacing="15.0" BorderPane.alignment="CENTER">
         <children>
            <TextField fx:id="newNameField" />
            <TextField fx:id="newPriceField" />
            <Button mnemonicParsing="false" onAction="#handleAddProduct" text="Thêm sản phẩm" />
         </children>
      </HBox>
   </bottom>
</BorderPane>
