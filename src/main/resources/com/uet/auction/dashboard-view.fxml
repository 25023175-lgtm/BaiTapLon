<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="600.0" prefWidth="850.0" stylesheets="@styles.css" styleClass="dashboard-root" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.uet.auction.DashboardController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="header-bar" BorderPane.alignment="CENTER">
            <children>
                <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1877F2;" text="Hệ thống Đấu giá UET" />
                <Region HBox.hgrow="ALWAYS" />
                <Button mnemonicParsing="false" onAction="#handleLogout" prefHeight="38.0" prefWidth="110.0" styleClass="btn-logout" text="Đăng xuất" />
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="15.0" style="-fx-padding: 20;">

            <HBox alignment="CENTER" spacing="20.0">
                <children>
                    <VBox alignment="CENTER" prefHeight="100.0" prefWidth="250.0" style="-fx-background-color: #f0ad4e; -fx-background-radius: 8; -fx-padding: 10;">
                        <Label fx:id="totalProductsLabel" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: white;" text="0" />
                        <Label style="-fx-font-size: 16px; -fx-text-fill: white;" text="Tổng số sản phẩm đang bán" />
                    </VBox>

                    <VBox alignment="CENTER" prefHeight="100.0" prefWidth="250.0" style="-fx-background-color: #5cb85c; -fx-background-radius: 8; -fx-padding: 10;">
                        <Label fx:id="highestPriceLabel" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;" text="0 VND" />
                        <Label fx:id="highestPriceNameLabel" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;" text="..." />
                        <Label style="-fx-font-size: 14px; -fx-text-fill: white; -fx-padding: 5 0 0 0;" text="Đang có giá cao nhất" />
                    </VBox>

                    <VBox alignment="CENTER" prefHeight="100.0" prefWidth="250.0" style="-fx-background-color: #5bc0de; -fx-background-radius: 8; -fx-padding: 10;">
                        <Label fx:id="mostBidsLabel" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;" text="0 lượt" />
                        <Label fx:id="mostBidsNameLabel" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;" text="..." />
                        <Label style="-fx-font-size: 14px; -fx-text-fill: white; -fx-padding: 5 0 0 0;" text="Được đấu giá nhiều nhất" />
                    </VBox>
                </children>
            </HBox>

            <TableView fx:id="productTable" VBox.vgrow="ALWAYS" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-font-size: 14px;">
                <columns>
                    <TableColumn fx:id="colName" prefWidth="160.0" text="Tên sản phẩm" />
                    <TableColumn fx:id="colStartPrice" prefWidth="140.0" text="Giá khởi điểm" />
                    <TableColumn fx:id="colDescription" prefWidth="200.0" text="Mô tả" />
                    <TableColumn fx:id="colStartTime" prefWidth="150.0" text="Thời gian đăng" />
                    <TableColumn fx:id="colEndTime" prefWidth="150.0" text="Kết thúc" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </VBox>
    </center>

    <bottom>
        <VBox style="-fx-padding: 0 20 20 20;" BorderPane.alignment="CENTER">
            <HBox fx:id="addProductBox" alignment="CENTER" spacing="8.0" styleClass="add-product-card">
                <children>
                    <TextField fx:id="newNameField" prefHeight="42.0" prefWidth="150.0" promptText="Tên SP..." style="-fx-font-size: 14px; -fx-background-radius: 6;" />
                    <TextField fx:id="newDescField" prefHeight="42.0" prefWidth="170.0" promptText="Mô tả..." style="-fx-font-size: 14px; -fx-background-radius: 6;" />
                    <TextField fx:id="newPriceField" prefHeight="42.0" prefWidth="110.0" promptText="Giá VND" style="-fx-font-size: 14px; -fx-background-radius: 6;" />
                    <TextField fx:id="newDurationField" prefHeight="42.0" prefWidth="110.0" promptText="TG (Phút)" style="-fx-font-size: 14px; -fx-background-radius: 6;" />

                    <Button minWidth="-Infinity" mnemonicParsing="false" onAction="#handleAddProduct" prefHeight="42.0" prefWidth="130.0" style="-fx-background-color: #42b72a; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" text="+ Thêm SP" />
                    <Button minWidth="-Infinity" mnemonicParsing="false" onAction="#handleDeleteProduct" prefHeight="42.0" prefWidth="80.0" style="-fx-background-color: #e41e3f; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" text="Xóa" />
                </children>
            </HBox>
        </VBox>
    </bottom>

</BorderPane>