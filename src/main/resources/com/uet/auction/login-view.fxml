<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="500.0" prefWidth="700.0" stylesheets="@styles.css" styleClass="root-background" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.uet.auction.LoginController">
   <children>

      <VBox alignment="CENTER" maxWidth="400.0" spacing="20.0" styleClass="login-card">
         <children>
            <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1877F2;" text="ĐĂNG NHẬP" />

            <TextField fx:id="usernameField" prefHeight="40.0" promptText="Tên đăng nhập" style="-fx-font-size: 14px;" />

            <StackPane alignment="CENTER_RIGHT">
               <children>
                  <PasswordField fx:id="hiddenPasswordField" prefHeight="40.0" promptText="Mật khẩu" style="-fx-font-size: 14px; -fx-padding: 0 40 0 10;" />
                  <TextField fx:id="visiblePasswordField" prefHeight="40.0" promptText="Mật khẩu" style="-fx-font-size: 14px; -fx-padding: 0 40 0 10;" visible="false" />
                  <ToggleButton fx:id="togglePasswordBtn" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-size: 16px;" text="👁" />
               </children>
            </StackPane>

            <Button mnemonicParsing="false" onAction="#handleLogin" prefHeight="45.0" prefWidth="400.0" style="-fx-background-color: #1877F2; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 8px; -fx-cursor: hand;" text="Đăng nhập" />

            <Hyperlink fx:id="registerLink" onAction="#handleSwitchToRegister" style="-fx-font-size: 14px; -fx-text-fill: #1877F2;" text="Chưa có tài khoản? Đăng kí ngay" />
         </children>
      </VBox>

   </children>
</VBox>
