name: UET Auction CI/CD Pipeline

on:
  push:
    branches: [ "main", "master" ]
  pull_request:
    branches: [ "main", "master" ]

jobs:
  build-test-checkstyle:
    runs-on: ubuntu-latest

    steps:
    - name: 1. Clone mã nguồn từ GitHub
      uses: actions/checkout@v4

    - name: 2. Thiết lập môi trường Java (JDK 21)
      uses: actions/setup-java@v4
      with:
        java-version: '21'
        distribution: 'temurin'
        cache: maven

    - name: 3. Chạy Checkstyle ép quy tắc đặt tên & Cú pháp
      run: mvn checkstyle:check

    - name: 4. Chạy Unit Test kiểm tra Code Coverage
      run: mvn test

    - name: 5. Build dự án (Đóng gói)
      run: mvn package -DskipTests